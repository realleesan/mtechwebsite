# ==========================================
# .htaccess - MTech Website
# Xử lý routing, error pages, bảo mật
# ==========================================

Options -Indexes

# ==========================================
# REWRITE ENGINE
# ==========================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ------------------------------------------
    # Bỏ qua các file/thư mục thực sự tồn tại
    # (assets, images, css, js, fonts...)
    # ------------------------------------------
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ------------------------------------------
    # Bỏ qua index.php (tránh loop)
    # ------------------------------------------
    RewriteRule ^index\.php$ - [L]

    # ------------------------------------------
    # Company History - Làm đẹp URL
    # /lich-su-hinh-thanh-phat-trien → index.php?page=company.history
    # ------------------------------------------
    RewriteRule ^lich-su-hinh-thanh-phat-trien$ index.php?page=company.history [L]

    # ------------------------------------------
    # About Us - Làm đẹp URL
    # /ve-chung-toi → index.php?page=about
    # ------------------------------------------
    RewriteRule ^ve-chung-toi$ index.php?page=about [L]

    # ------------------------------------------
    # Awards & Certificates - Làm đẹp URL
    # /giai-thuong-chung-chi → index.php?page=awards
    # ------------------------------------------
    RewriteRule ^giai-thuong-chung-chi$ index.php?page=awards [L]

    # ------------------------------------------
    # Contact - Làm đẹp URL
    # /lien-he → index.php?page=contact
    # ------------------------------------------
    RewriteRule ^lien-he$ index.php?page=contact [L]

    # ------------------------------------------
    # Projects - Làm đẹp URL
    # /du-an → index.php?page=projects
    # ------------------------------------------
    RewriteRule ^du-an$ index.php?page=projects [L]

    # ------------------------------------------
    # Project Details - Làm đẹp URL
    # /chi-tiet-du-an-{slug} → index.php?page=project-details&slug={slug}
    # Ví dụ: /chi-tiet-du-an-welding-processing
    # ------------------------------------------
    RewriteRule ^chi-tiet-du-an-(.+)$ index.php?page=project-details&slug=$1 [L,QSA]

    # ------------------------------------------
    # Tuyển dụng - Làm đẹp URL
    # /tuyen-dung → index.php?page=blogs&cat=7
    # ------------------------------------------
    RewriteRule ^tuyen-dung$ index.php?page=blogs&cat=7 [L]

    # ------------------------------------------
    # Mọi URL path không tồn tại → index.php?page=404
    # Ví dụ: /444, /abc, /xyz → index.php?page=404
    # ------------------------------------------
    RewriteRule ^ index.php?page=404 [L,R=302]
</IfModule>

# ==========================================
# ERROR DOCUMENTS
# Dùng trang lỗi tùy chỉnh của website
# ==========================================

# Lỗi 404 - Không tìm thấy trang
ErrorDocument 404 /index.php?page=404

# Lỗi 500 - Lỗi máy chủ nội bộ
ErrorDocument 500 /index.php?page=500

# Lỗi 403 - Không có quyền truy cập (dùng chung trang 404)
ErrorDocument 403 /index.php?page=404

# ==========================================
# SECURITY HEADERS
# ==========================================
<IfModule mod_headers.c>
    # Chống clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Chống MIME sniffing
    Header always set X-Content-Type-Options "nosniff"
    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# ==========================================
# CACHE CONTROL - Tối ưu tốc độ tải
# ==========================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
</IfModule>

# ==========================================
# GZIP COMPRESSION - Nén file để tải nhanh hơn
# ==========================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
</IfModule>

# ==========================================
# PROTECT SENSITIVE FILES
# Chặn truy cập trực tiếp vào file nhạy cảm
# ==========================================
<FilesMatch "\.(env|log|sql|md|json|lock|git)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Chặn truy cập thư mục .git
<IfModule mod_rewrite.c>
    RewriteRule ^\.git - [F,L]
</IfModule>
